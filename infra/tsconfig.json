{
  "extends":[
    "../tsconfig.json"
  ],
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "es2022",
    "lib": ["es2022"],
    "isolatedModules": true,
    "typeRoots": [
      "./node_modules/@types"
    ],
    "outDir": "./dist",
  },
  "include": [
    "./**/*",
    "../common/**/*"
  ],
  "exclude": [
    "node_modules",
    "cdk.out",
    "dist",
    "**/*.test.ts"
  ]
}
